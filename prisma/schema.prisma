generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ===== AUTH =====

model User {
  id        Int      @id @default(autoincrement())
  microsoftId String @unique @map("microsoft_id")
  email     String   @unique
  nombre    String
  avatar    String?
  rol       Rol      @default(tecnico)
  activo    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  informesCreados Informe[]

  @@map("usuarios")
}

enum Rol {
  admin
  tecnico
}

// ===== JERARQUIA DOMINIO =====

model Cliente {
  id                  Int       @id @default(autoincrement())
  nombre              String
  sede                String?
  direccion           String?
  ciudad              String?
  codigoPostal        String?   @map("codigo_postal")
  provincia           String?
  telefono            String?
  email               String?
  personaContacto     String?   @map("persona_contacto")
  logo                String?
  // Tarifas
  tarifaHoraTrabajo   Decimal?  @map("tarifa_hora_trabajo") @db.Decimal(10, 2)
  tarifaHoraViaje     Decimal?  @map("tarifa_hora_viaje") @db.Decimal(10, 2)
  dietas              Decimal?  @db.Decimal(10, 2)
  gestionAccesos      Decimal?  @map("gestion_accesos") @db.Decimal(10, 2)
  // Logistica viaje
  horasTrayecto       Decimal?  @map("horas_trayecto") @db.Decimal(8, 2)
  diasViaje           Decimal?  @map("dias_viaje") @db.Decimal(8, 2)
  km                  Decimal?  @db.Decimal(10, 2)
  peajes              Decimal?  @db.Decimal(10, 2)
  precioHotel         Decimal?  @map("precio_hotel") @db.Decimal(10, 2)
  precioKm            Decimal?  @map("precio_km") @db.Decimal(10, 2)
  activo              Boolean   @default(true)
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  plantas        Planta[]
  maquinas       Maquina[]
  sistemas       Sistema[]
  intervenciones Intervencion[]
  ofertas        Oferta[]

  @@map("clientes")
}

model Planta {
  id        Int      @id @default(autoincrement())
  clienteId Int      @map("cliente_id")
  nombre    String   @db.VarChar(191)
  direccion String?  @db.VarChar(191)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cliente  Cliente   @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  maquinas Maquina[]
  sistemas Sistema[]

  @@map("plantas")
}

model Maquina {
  id          Int      @id @default(autoincrement())
  clienteId   Int      @map("cliente_id")
  plantaId    Int      @map("planta_id")
  nombre      String
  descripcion String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  cliente  Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  planta   Planta   @relation(fields: [plantaId], references: [id], onDelete: Cascade)
  sistemas Sistema[]

  @@unique([clienteId, nombre])
  @@map("maquinas")
}

// ===== LOOKUPS v2 =====

model LuGeneracionControlador {
  id          Int      @id @default(autoincrement())
  codigo      String   @unique @db.VarChar(50)
  nombre      String   @db.VarChar(100)
  driveSystem String?  @map("drive_system") @db.VarChar(50)
  anioDesde   Int?     @map("anio_desde") @db.SmallInt
  anioHasta   Int?     @map("anio_hasta") @db.SmallInt
  activo      Boolean  @default(true)
  orden       Int      @default(0)
  notas       String?  @db.Text

  modelos ModeloComponente[]

  @@map("lu_generacion_controlador")
}

model LuFamilia {
  id            Int            @id @default(autoincrement())
  fabricanteId  Int            @map("fabricante_id")
  codigo        String         @db.VarChar(80)
  tipo          TipoComponente
  descripcion   String?        @db.VarChar(255)
  activa        Boolean        @default(true)

  fabricante             Fabricante                       @relation(fields: [fabricanteId], references: [id])
  modelos                ModeloComponente[]
  actividadesPreventivas ActividadPreventiva[]
  equivalencias          EquivalenciaFamilia[]
  compatEjePermitida     CompatibilidadEjePermitida[]
  compatEjeExcluye       CompatibilidadEjeExcluye[]
  compatRobotCtrl        CompatibilidadRobotControlador[]
  mantenimientoHoras     MantenimientoHorasFamilia[]

  @@unique([fabricanteId, codigo, tipo], map: "uq_fam_fab_cod")
  @@map("lu_familia")
}

model LuTipoActividad {
  id              Int     @id @default(autoincrement())
  codigo          String  @unique @db.VarChar(50)
  nombre          String  @db.VarChar(100)
  categoria       LuTipoActividadCategoria @default(otro)
  requiereParada  Boolean @default(true) @map("requiere_parada")
  orden           Int     @default(0)

  actividadesPreventivas ActividadPreventiva[]
  actividadesCabinet     ActividadCabinet[]
  actividadesDriveModule ActividadDriveModule[]

  @@map("lu_tipo_actividad")
}

enum LuTipoActividadCategoria {
  inspeccion
  lubricacion
  reemplazo
  overhaul
  analisis
  bateria
  correa
  filtro
  desiccant
  limpieza
  otro
}

enum LuNivelMantenimientoAmbito {
  manipulador
  controlador
  drive_unit
  eje_externo
}

model LuUnidadIntervalo {
  id          Int      @id @default(autoincrement())
  codigo      String   @unique @db.VarChar(30)
  nombre      String   @db.VarChar(50)
  factorHoras Decimal? @map("factor_horas") @db.Decimal(12, 4)
  orden       Int      @default(0)

  @@map("lu_unidad_intervalo")
}

model LuNivelMantenimiento {
  id          Int                       @id @default(autoincrement())
  codigo      String                    @unique @db.VarChar(20)
  nombre      String                    @db.VarChar(50)
  descripcion String?                   @db.VarChar(255)
  ambito      LuNivelMantenimientoAmbito @default(manipulador)
  orden       Int

  modelosAplicables   ModeloNivelAplicable[]
  actividades         ActividadNivel[]
  horasFamilia        MantenimientoHorasFamilia[]
  horasModelo         MantenimientoHorasModelo[]
  consumiblesNivel    ConsumibleNivel[]
  ofertaComponentes   OfertaComponente[]
  ofertaSistemas      OfertaSistema[]
  intervencionSistemas IntervencionSistema[]

  @@map("lu_nivel_mantenimiento")
}

// ===== CATALOGOS =====

model Fabricante {
  id        Int      @id @default(autoincrement())
  nombre    String   @unique
  activo    Boolean  @default(true)
  orden     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  modelos                  ModeloComponente[]
  sistemas                 Sistema[]
  familias                 LuFamilia[]
  lubricacionReductoras    LubricacionReductora[]
  actividadesMantenimiento ActividadMantenimiento[]

  @@map("fabricantes")
}

model ModeloComponente {
  id                      Int            @id @default(autoincrement())
  fabricanteId            Int            @map("fabricante_id")
  tipo                    TipoComponente
  familia                 String?        @db.VarChar(200)  // legacy, mantener
  familiaId               Int?           @map("familia_id")
  generacionControladorId Int?           @map("generacion_controlador_id")
  nombre                  String
  notas                   String?        @db.Text
  aceitesConfig           Json?          @map("aceites_config")  // legacy
  niveles                 String?        // legacy CSV: "1,2,2_inferior,2_superior,3"
  // Capacidades de controladora (solo para tipo='controller')
  soportaMultimove        Boolean?       @map("soporta_multimove")
  maxRobotsMultimove      Int?           @map("max_robots_multimove") @db.TinyInt
  maxEjesExternos         Int?           @map("max_ejes_externos") @db.TinyInt
  // Tipo de bateria de medida (solo aplica a mechanical_unit)
  tipoBateriaMedida       TipoBateriaMedida? @map("tipo_bateria_medida")
  createdAt               DateTime       @default(now()) @map("created_at")
  updatedAt               DateTime       @updatedAt @map("updated_at")

  fabricante               Fabricante                   @relation(fields: [fabricanteId], references: [id], onDelete: Cascade)
  familiaRel               LuFamilia?                   @relation(fields: [familiaId], references: [id])
  generacion               LuGeneracionControlador?     @relation(fields: [generacionControladorId], references: [id])
  controladoresCompatibles CompatibilidadControlador[]   @relation("ComponenteCompat")
  componentesCompatibles   CompatibilidadControlador[]   @relation("ControladorCompat")
  versiones                VersionTemplate[]
  componentes              ComponenteSistema[]
  consumiblesNivel         ConsumibleNivel[]
  mantenimientoHoras       MantenimientoHorasModelo[]
  mantenimientoHorasFamilia MantenimientoHorasFamilia[]   @relation("HorasFamiliaModelo")
  mantenimientoHorasComoCtrl MantenimientoHorasFamilia[]  @relation("HorasFamiliaCtrl")
  consumiblesLimpieza      ConsumibleLimpiezaModelo[]
  nivelesAplicables        ModeloNivelAplicable[]
  lubricaciones            Lubricacion[]
  actividadesCabinet       ActividadCabinet[]
  actividadesDriveModule   ActividadDriveModule[]        @relation("DriveModuleModelo")
  actividadesDriveModuleCtrl ActividadDriveModule[]      @relation("DriveModuleCtrl")
  compatEjePermitida       CompatibilidadEjePermitida[]
  compatEjeExcluye         CompatibilidadEjeExcluye[]
  compatEjeControladorEje  CompatibilidadEjeControlador[] @relation("EjeCtrlEje")
  compatEjeControladorCtrl CompatibilidadEjeControlador[] @relation("EjeCtrlCtrl")
  compatRobotCtrl          CompatibilidadRobotControlador[] @relation("RobotCtrlControlador")

  @@unique([fabricanteId, tipo, nombre], map: "modelos_componente_fab_tipo_nombre")
  @@map("modelos_componente")
}

model CompatibilidadControlador {
  controladorId Int     @map("controlador_id")
  componenteId  Int     @map("componente_id")
  notas         String? @db.VarChar(255)

  controlador ModeloComponente @relation("ControladorCompat", fields: [controladorId], references: [id], onDelete: Cascade)
  componente  ModeloComponente @relation("ComponenteCompat", fields: [componenteId], references: [id], onDelete: Cascade)

  @@id([controladorId, componenteId])
  @@map("compatibilidad_controlador")
}

enum TipoComponente {
  controller
  mechanical_unit
  drive_unit
  external_axis
}

model VersionTemplate {
  id                 Int            @id @default(autoincrement())
  modeloComponenteId Int            @map("modelo_componente_id")
  version            Int
  estado             EstadoTemplate @default(borrador)
  schema             Json
  notas              String?        @db.Text
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  modeloComponente   ModeloComponente  @relation(fields: [modeloComponenteId], references: [id], onDelete: Cascade)
  componentesInforme ComponenteInforme[]

  @@unique([modeloComponenteId, version])
  @@map("versiones_template")
}

enum EstadoTemplate {
  borrador
  activo
  obsoleto
}

// ===== MODELO x NIVEL (normalizado desde CSV) =====

model ModeloNivelAplicable {
  modeloComponenteId Int @map("modelo_componente_id")
  nivelId            Int @map("nivel_id")

  modelo ModeloComponente     @relation(fields: [modeloComponenteId], references: [id], onDelete: Cascade)
  nivel  LuNivelMantenimiento @relation(fields: [nivelId], references: [id])

  @@id([modeloComponenteId, nivelId])
  @@map("modelo_nivel_aplicable")
}

// ===== SISTEMAS =====

model Sistema {
  id           Int      @id @default(autoincrement())
  clienteId    Int      @map("cliente_id")
  plantaId     Int?     @map("planta_id")
  maquinaId    Int?     @map("maquina_id")
  fabricanteId Int      @map("fabricante_id")
  nombre       String
  descripcion  String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  cliente        Cliente              @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  planta         Planta?              @relation(fields: [plantaId], references: [id], onDelete: SetNull)
  maquina        Maquina?             @relation(fields: [maquinaId], references: [id], onDelete: SetNull)
  fabricante     Fabricante           @relation(fields: [fabricanteId], references: [id], onDelete: Cascade)
  componentes    ComponenteSistema[]
  intervenciones IntervencionSistema[]
  informes       Informe[]
  ofertas        OfertaSistema[]

  @@unique([clienteId, fabricanteId, nombre])
  @@map("sistemas")
}

model ComponenteSistema {
  id                  Int            @id @default(autoincrement())
  sistemaId           Int            @map("sistema_id")
  modeloComponenteId  Int            @map("modelo_componente_id")
  tipo                TipoComponente
  etiqueta            String
  numeroSerie         String?        @map("numero_serie")
  numEjes             Int?           @map("num_ejes")
  metadata            Json?
  orden               Int            @default(0)
  componentePadreId   Int?           @map("componente_padre_id")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  sistema            Sistema             @relation(fields: [sistemaId], references: [id], onDelete: Cascade)
  modeloComponente   ModeloComponente    @relation(fields: [modeloComponenteId], references: [id])
  padre              ComponenteSistema?  @relation("ComponenteJerarquia", fields: [componentePadreId], references: [id], onDelete: SetNull)
  hijos              ComponenteSistema[] @relation("ComponenteJerarquia")
  componentesInforme ComponenteInforme[]
  ofertaComponentes  OfertaComponente[]

  @@index([componentePadreId])
  @@map("componentes_sistema")
}

// ===== INTERVENCIONES E INFORMES =====

model Intervencion {
  id          Int                @id @default(autoincrement())
  clienteId   Int                @map("cliente_id")
  ofertaId    Int?               @map("oferta_id")
  tipo        TipoIntervencion
  estado      EstadoIntervencion @default(borrador)
  referencia  String?
  titulo      String
  fechaInicio DateTime?          @map("fecha_inicio")
  fechaFin    DateTime?          @map("fecha_fin")
  notas       String?            @db.Text
  tarifaHoraTrabajo   Decimal?   @map("tarifa_hora_trabajo") @db.Decimal(10, 2)
  tarifaHoraViaje     Decimal?   @map("tarifa_hora_viaje") @db.Decimal(10, 2)
  dietas              Decimal?   @db.Decimal(10, 2)
  gestionAccesos      Decimal?   @map("gestion_accesos") @db.Decimal(10, 2)
  horasTrayecto       Decimal?   @map("horas_trayecto") @db.Decimal(8, 2)
  diasViaje           Decimal?   @map("dias_viaje") @db.Decimal(8, 2)
  km                  Decimal?   @db.Decimal(10, 2)
  peajes              Decimal?   @db.Decimal(10, 2)
  precioHotel         Decimal?   @map("precio_hotel") @db.Decimal(10, 2)
  precioKm            Decimal?   @map("precio_km") @db.Decimal(10, 2)
  gestionAccesosNueva Boolean    @default(false) @map("gestion_accesos_nueva")
  numeroTecnicos      Int        @default(1) @map("numero_tecnicos")
  viajesIdaVuelta     Int        @default(1) @map("viajes_ida_vuelta")
  incluyeConsumibles  Boolean    @default(true) @map("incluye_consumibles")
  horasDia            Decimal?   @map("horas_dia") @db.Decimal(8, 2)
  dietasExtra         Decimal?   @map("dietas_extra") @db.Decimal(10, 2)
  diasTrabajo         String?    @map("dias_trabajo")
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")

  cliente      Cliente              @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  sistemas     IntervencionSistema[]
  informes     Informe[]
  pedidoCompra PedidoCompra?

  @@map("intervenciones")
}

enum TipoIntervencion {
  preventiva
  correctiva
}

enum EstadoIntervencion {
  borrador
  en_curso
  completada
  facturada
}

model IntervencionSistema {
  intervencionId Int @map("intervencion_id")
  sistemaId      Int @map("sistema_id")
  nivelId        Int @map("nivel_id")

  intervencion Intervencion         @relation(fields: [intervencionId], references: [id], onDelete: Cascade)
  sistema      Sistema              @relation(fields: [sistemaId], references: [id], onDelete: Cascade)
  nivel        LuNivelMantenimiento @relation(fields: [nivelId], references: [id])

  @@id([intervencionId, sistemaId])
  @@map("intervencion_sistema")
}

model Informe {
  id               Int           @id @default(autoincrement())
  intervencionId   Int           @map("intervencion_id")
  sistemaId        Int           @map("sistema_id")
  estado           EstadoInforme @default(inactivo)
  fechaRealizacion DateTime?     @map("fecha_realizacion")
  notas            String?       @db.Text
  datosDocumento   Json          @default("{}") @map("datos_documento")
  creadoPorId      Int?          @map("creado_por_id")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  intervencion Intervencion      @relation(fields: [intervencionId], references: [id], onDelete: Cascade)
  sistema      Sistema           @relation(fields: [sistemaId], references: [id], onDelete: Cascade)
  creadoPor    User?             @relation(fields: [creadoPorId], references: [id])
  componentes  ComponenteInforme[]

  @@unique([intervencionId, sistemaId])
  @@map("informes")
}

enum EstadoInforme {
  inactivo
  activo
  finalizado
}

model ComponenteInforme {
  id                  Int            @id @default(autoincrement())
  informeId           Int            @map("informe_id")
  componenteSistemaId Int            @map("componente_sistema_id")
  versionTemplateId   Int            @map("version_template_id")
  tipoComponente      TipoComponente @map("tipo_componente")
  etiqueta            String
  orden               Int            @default(0)
  schemaCongelado     Json           @map("schema_congelado")
  datos               Json           @default("{}")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  informe           Informe           @relation(fields: [informeId], references: [id], onDelete: Cascade)
  componenteSistema ComponenteSistema @relation(fields: [componenteSistemaId], references: [id])
  versionTemplate   VersionTemplate   @relation(fields: [versionTemplateId], references: [id])

  @@unique([informeId, componenteSistemaId])
  @@map("componentes_informe")
}

// ===== CATALOGOS ACEITES Y CONSUMIBLES =====

model Aceite {
  id              Int      @id @default(autoincrement())
  nombre          String
  codigoCanonico  String?  @unique @map("codigo_canonico") @db.VarChar(100)
  fabricante      String?
  unidad          String?
  categoria       AceiteCategoria @default(otro)
  notasTecnicas   String?  @map("notas_tecnicas") @db.Text
  fabricanteRobot String?  @map("fabricante_robot")
  coste           Decimal? @db.Decimal(10, 2)
  precio          Decimal? @db.Decimal(10, 2)
  activo          Boolean  @default(true)
  consumibleId    Int?     @map("consumible_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  alias         AceiteAlias[]
  lubricaciones Lubricacion[]
  consumible    ConsumibleCatalogo? @relation(fields: [consumibleId], references: [id])

  @@map("aceites")
}

enum AceiteCategoria {
  aceite
  grasa
  food_grade
  foundry
  harmonic
  otro
}

model AceiteAlias {
  id       Int    @id @default(autoincrement())
  aceiteId Int    @map("aceite_id")
  alias    String @unique @db.VarChar(200)

  aceite Aceite @relation(fields: [aceiteId], references: [id], onDelete: Cascade)

  @@map("aceite_alias")
}

model Consumible {
  id               Int      @id @default(autoincrement())
  nombre           String
  fabricante       String?
  tipo             String   @default("general")
  compatibleCon    String?  @map("compatible_con")
  refOriginal      String?  @map("ref_original")
  refProveedor     String?  @map("ref_proveedor")
  denominacion     String?
  fabricanteRobot  String?  @map("fabricante_robot")
  coste            Decimal? @db.Decimal(10, 2)
  precio           Decimal? @db.Decimal(10, 2)
  activo           Boolean  @default(true)
  consumibleId     Int?     @map("consumible_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  consumible       ConsumibleCatalogo? @relation(fields: [consumibleId], references: [id])

  @@map("consumibles")
}

// Catalogo unificado de consumibles (v2) — fuente de verdad para
// pedidos y trazabilidad de aceites/grasas/baterias/filtros/etc.
model ConsumibleCatalogo {
  id              Int      @id @default(autoincrement())
  tipo            ConsumibleTipo
  subtipo         String?  @db.VarChar(80)
  nombre          String   @unique @db.VarChar(200)
  codigoAbb       String?  @map("codigo_abb") @db.VarChar(80)
  fabricante      String?  @db.VarChar(100)
  unidad          String?  @db.VarChar(20)
  equivalencias   String?  @db.Text
  apariciones     Int      @default(0)
  coste           Decimal? @db.Decimal(10, 2)
  precio          Decimal? @db.Decimal(10, 2)
  fabricanteRobot String?  @map("fabricante_robot") @db.VarChar(100)
  refOriginal     String?  @map("ref_original") @db.VarChar(100)
  refProveedor    String?  @map("ref_proveedor") @db.VarChar(100)
  notas           String?  @db.Text
  activo          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  lubricaciones      Lubricacion[]
  actividadesPrev    ActividadConsumible[]
  actividadesCabinet ActividadCabinetConsumible[]
  actividadesDriveMod ActividadDriveModuleConsumible[]
  puntosControl      PuntoControlGenerico[]
  aceitesLegacy      Aceite[]
  consumiblesLegacy  Consumible[]
  limpiezaModelo     ConsumibleLimpiezaModelo[]

  @@map("consumible_catalogo")
}

enum ConsumibleTipo {
  aceite
  grasa
  bateria
  filtro
  ventilador
  rodamiento
  sello
  cable
  ball_screw
  tope_mecanico
  tarjeta
  desiccant
  limpieza
  otro
}

model ConsumibleNivel {
  id              Int            @id @default(autoincrement())
  modeloId        Int            @map("modelo_id")
  nivelId         Int            @map("nivel_id")
  horas           Decimal?       @db.Decimal(8, 2)
  precioOtros     Decimal?       @db.Decimal(10, 2) @map("precio_otros")
  consumibles     Json?
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  modelo ModeloComponente     @relation(fields: [modeloId], references: [id], onDelete: Cascade)
  nivel  LuNivelMantenimiento @relation(fields: [nivelId], references: [id])

  @@unique([modeloId, nivelId], map: "uq_cn_modelo_nivel")
  @@map("consumibles_nivel")
}

// ===== OFERTAS =====

enum TipoBateriaMedida {
  smb
  eib
}

// Horas de trabajo + coste consumibles de limpieza por (modelo, nivel) — LEGACY
// Sustituida por MantenimientoHorasFamilia + ConsumibleLimpiezaModelo
model MantenimientoHorasModelo {
  id                  Int      @id @default(autoincrement())
  modeloComponenteId  Int      @map("modelo_componente_id")
  nivelId             Int      @map("nivel_id")
  horas               Decimal? @db.Decimal(8, 2)
  costeLimpieza       Decimal? @map("coste_limpieza") @db.Decimal(10, 2)
  notas               String?  @db.VarChar(500)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  modelo ModeloComponente     @relation(fields: [modeloComponenteId], references: [id], onDelete: Cascade)
  nivel  LuNivelMantenimiento @relation(fields: [nivelId], references: [id])

  @@unique([modeloComponenteId, nivelId], map: "uq_mhm")
  @@map("mantenimiento_horas_modelo")
}

// Horas de trabajo por (familia, nivel). Para mech_unit/external_axis/drive_unit
// se usa solo familia (modelo=null). Para controlador se usa modelo concreto
// (variante de la familia, p.ej. IRC5 Compact vs IRC5 Single).
// controladorModeloId: solo aplica a manipulador (las horas dependen del cabinet).
// revisado: marca filas validadas manualmente vs pendientes de revisar en seed.
model MantenimientoHorasFamilia {
  id                    Int      @id @default(autoincrement())
  familiaId             Int      @map("familia_id")
  modeloComponenteId    Int?     @map("modelo_componente_id")
  controladorModeloId   Int?     @map("controlador_modelo_id")
  nivelId               Int      @map("nivel_id")
  horas                 Decimal? @db.Decimal(8, 2)
  revisado              Boolean  @default(false)
  notas                 String?  @db.VarChar(500)
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  familia      LuFamilia            @relation(fields: [familiaId], references: [id], onDelete: Cascade)
  modelo       ModeloComponente?    @relation("HorasFamiliaModelo", fields: [modeloComponenteId], references: [id], onDelete: Cascade)
  controlador  ModeloComponente?    @relation("HorasFamiliaCtrl", fields: [controladorModeloId], references: [id], onDelete: Cascade)
  nivel        LuNivelMantenimiento @relation(fields: [nivelId], references: [id])

  @@unique([familiaId, modeloComponenteId, controladorModeloId, nivelId], map: "uq_mhf")
  @@index([familiaId])
  @@index([modeloComponenteId])
  @@index([controladorModeloId])
  @@map("mantenimiento_horas_familia")
}

// Consumibles de limpieza vinculados al modelo (no por nivel; aplican siempre)
model ConsumibleLimpiezaModelo {
  id                  Int      @id @default(autoincrement())
  modeloComponenteId  Int      @map("modelo_componente_id")
  consumibleId        Int      @map("consumible_id")
  cantidad            Decimal  @db.Decimal(10, 3) @default(1)
  unidad              String?  @db.VarChar(20)
  notas               String?  @db.VarChar(255)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  modelo     ModeloComponente   @relation(fields: [modeloComponenteId], references: [id], onDelete: Cascade)
  consumible ConsumibleCatalogo @relation(fields: [consumibleId], references: [id], onDelete: Cascade)

  @@unique([modeloComponenteId, consumibleId], map: "uq_clm")
  @@index([modeloComponenteId])
  @@map("consumibles_limpieza_modelo")
}

enum TipoOferta {
  mantenimiento
  solo_limpieza
}

model Oferta {
  id            Int            @id @default(autoincrement())
  clienteId     Int            @map("cliente_id")
  titulo        String
  referencia    String?
  tipo          TipoIntervencion
  tipoOferta    TipoOferta     @default(mantenimiento) @map("tipo_oferta")
  estado        String         @default("borrador")
  fechaOferta   DateTime       @default(now()) @map("fecha_oferta")
  validezDias   Int            @default(30) @map("validez_dias")
  notas         String?        @db.Text
  totalHoras    Decimal?       @db.Decimal(8, 2) @map("total_horas")
  totalCoste    Decimal?       @db.Decimal(10, 2) @map("total_coste")
  totalPrecio   Decimal?       @db.Decimal(10, 2) @map("total_precio")
  fechaInicio       DateTime?  @map("fecha_inicio")
  fechaFin          DateTime?  @map("fecha_fin")
  horaInicioJornada String?    @map("hora_inicio_jornada")
  horaFinJornada    String?    @map("hora_fin_jornada")
  diasTrabajo       String?    @map("dias_trabajo")
  desgloseRecargo   Json?      @map("desglose_recargo")
  totalRecargo      Decimal?   @db.Decimal(10, 2) @map("total_recargo")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  cliente     Cliente            @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  sistemas    OfertaSistema[]
  componentes OfertaComponente[]
  bloques     OfertaBloqueCalendario[]

  @@map("ofertas")
}

enum TipoBloqueOferta {
  trabajo
  desplazamiento
  comida
}

enum OrigenBloqueOferta {
  componente
  desplazamiento
  manual
  comida
}

// Bloque de tiempo en el calendario de planificacion de una oferta
model OfertaBloqueCalendario {
  id                  Int                 @id @default(autoincrement())
  ofertaId            Int                 @map("oferta_id")
  fecha               DateTime            @db.Date
  horaInicio          String              @map("hora_inicio") @db.VarChar(8)
  horaFin             String              @map("hora_fin") @db.VarChar(8)
  tipo                TipoBloqueOferta
  ofertaComponenteId  Int?                @map("oferta_componente_id")
  origenTipo          OrigenBloqueOferta  @default(manual) @map("origen_tipo")
  notas               String?             @db.VarChar(500)
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  oferta            Oferta            @relation(fields: [ofertaId], references: [id], onDelete: Cascade)
  ofertaComponente  OfertaComponente? @relation(fields: [ofertaComponenteId], references: [id], onDelete: SetNull)

  @@index([ofertaId])
  @@index([ofertaId, fecha])
  @@index([ofertaComponenteId])
  @@map("oferta_bloque_calendario")
}

// Detalle por componente del sistema en una oferta
model OfertaComponente {
  id                    Int      @id @default(autoincrement())
  ofertaId              Int      @map("oferta_id")
  componenteSistemaId   Int      @map("componente_sistema_id")
  nivelId               Int?     @map("nivel_id")
  conBaterias           Boolean  @default(true) @map("con_baterias")
  conAceite             Boolean  @default(true) @map("con_aceite")
  horas                 Decimal? @db.Decimal(8, 2)
  costeConsumibles      Decimal? @map("coste_consumibles") @db.Decimal(10, 2)
  precioConsumibles     Decimal? @map("precio_consumibles") @db.Decimal(10, 2)
  costeLimpieza         Decimal? @map("coste_limpieza") @db.Decimal(10, 2)
  notas                 String?  @db.VarChar(500)
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  oferta            Oferta                @relation(fields: [ofertaId], references: [id], onDelete: Cascade)
  componenteSistema ComponenteSistema     @relation(fields: [componenteSistemaId], references: [id], onDelete: Cascade)
  nivel             LuNivelMantenimiento? @relation(fields: [nivelId], references: [id])
  bloques           OfertaBloqueCalendario[]

  @@unique([ofertaId, componenteSistemaId], map: "uq_oc")
  @@map("oferta_componente")
}

model OfertaSistema {
  ofertaId          Int      @map("oferta_id")
  sistemaId         Int      @map("sistema_id")
  nivelId           Int      @map("nivel_id")
  horas             Decimal? @db.Decimal(8, 2)
  costeConsumibles  Decimal? @db.Decimal(10, 2) @map("coste_consumibles")
  precioConsumibles Decimal? @db.Decimal(10, 2) @map("precio_consumibles")

  oferta  Oferta              @relation(fields: [ofertaId], references: [id], onDelete: Cascade)
  sistema Sistema             @relation(fields: [sistemaId], references: [id], onDelete: Cascade)
  nivel   LuNivelMantenimiento @relation(fields: [nivelId], references: [id])

  @@id([ofertaId, sistemaId])
  @@map("oferta_sistema")
}

